# Runtime data (SQLite library cache, uploads, local state)
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
coverage/
.nyc_output/

# OS / editor junk
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
