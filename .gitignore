# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/
*.tsbuildinfo

# Environment & secrets — never commit real credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials.json
service-account*.json
secrets/
.secret*
*.secret
auth.json
.npmrc
# Allow a committed example npmrc only if we add one later:
# !.npmrc.example

# Runtime data (SQLite library cache / local state)
# Keep the folder in git; ignore everything inside it.
/data/*
!/data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
coverage/
.nyc_output/

# OS / editor junk
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
*~

# Temp / convert scratch (if created under project root)
*.wtf-tmp.mp4
*.wtf-new.mp4
.wtf-originals/
*.tmp
*.temp

# Optional local tooling
.turbo/
.cache/
tmp/
temp/
tsc-out.txt
.eslintcache
.vite/
