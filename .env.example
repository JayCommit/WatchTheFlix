# SFTPGo WebDAV base URL (no trailing path required if WebDAV is on this host/port)
SFTPGO_WEBDAV_URL=https://your-seedbox.example.com:29765
SFTPGO_USER=your_username
SFTPGO_PASSWORD=your_password

# Folder(s) inside WebDAV to scan. Use MEDIA_ROOTS for multiple (comma-separated).
MEDIA_ROOT=/storage/Media
# MEDIA_ROOTS=/storage/Media/Movies,/storage/Media/TV Shows,/storage/Media/Anime
# Skip paths containing these substrings (comma-separated)
# SCAN_IGNORE=/sample/,/@eaDir/

# TMDB API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Server
PORT=8787
# Use a long random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Accounts: first registered user becomes admin. Legacy APP_PASSWORD is no longer used for login.
# Allow anyone to self-register as a normal user after setup (default off — admins create users)
ALLOW_PUBLIC_REGISTRATION=false

# Local disk mount for convert jobs + optional local streaming (Ubuntu container)
# Map your media volume here, e.g. /media. Library paths under MEDIA_ROOT are
# resolved relative to this root.
LOCAL_MEDIA_ROOT=

# Convert queue (admin Convert tab)
CONVERT_CONCURRENCY=1
# Default for "delete original after verified replace" — leave false; per-job toggle in UI
CONVERT_DELETE_ORIGINAL=false

# Optional system FFmpeg (recommended on seedbox). Falls back to bundled binaries.
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
# Hardware encode for live transcode + convert: auto | software | nvenc | vaapi | qsv | none
FFMPEG_HW=auto

# Auto library scan interval in minutes (0 = manual only)
SCAN_INTERVAL_MINUTES=0
