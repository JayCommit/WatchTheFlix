# SFTPGo WebDAV base URL (no trailing path required if WebDAV is on this host/port)
SFTPGO_WEBDAV_URL=https://your-seedbox.example.com:29765
SFTPGO_USER=your_username
SFTPGO_PASSWORD=your_password

# Folder inside WebDAV to scan (must exist — e.g. /storage/Media)
MEDIA_ROOT=/storage/Media

# TMDB API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Password required to open the UI (change before any real deploy)
APP_PASSWORD=changeme

# Server
PORT=8787
# Use a long random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Local disk mount for convert jobs + optional local streaming (Ubuntu container)
# Map your media volume here, e.g. /media. Library paths under MEDIA_ROOT are
# resolved relative to this root.
LOCAL_MEDIA_ROOT=

# Convert queue (admin Convert tab)
CONVERT_CONCURRENCY=1
# Default for "delete original after verified replace" — leave false; per-job toggle in UI
CONVERT_DELETE_ORIGINAL=false

# Optional system FFmpeg (recommended on seedbox). Falls back to bundled binaries.
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
